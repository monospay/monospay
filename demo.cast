[1.506, "o", "\u001b[90m# Step 2: First run — see what's needed\u001b[0m\r\n$ mono-mcp\r\n"]
[0.411, "o", "\r\n  monospay · payment infrastructure for AI agents\r\n"]
[0.000, "o", "  ─────────────────────────────────────────────────\r\n\r\n"]
[0.000, "o", "  Almost there! Two steps to connect your agent:\r\n\r\n"]
[0.000, "o", "  1. Get your keys at monospay.com/dashboard\r\n"]
[0.000, "o", "     → Agents → select agent → Issue API key\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  2. Set them in your environment:\r\n"]
[0.000, "o", "     export MONO_API_KEY=mono_live_...\r\n     export MONO_PRIVATE_KEY=0x...\r\n"]
[0.000, "o", "\r\n"]
[3.030, "o", "\u001b[90m# Step 3: Set keys and go\u001b[0m\r\n$ export MONO_API_KEY=mono_live_abc123\r\n"]
[0.410, "o", "$ export MONO_PRIVATE_KEY=0xdef456...\r\n"]
[0.407, "o", "$ mono-mcp\r\n"]
[0.408, "o", "\r\n"]
[0.001, "o", "  \u001b[32m✓ monospay ready — your agent can pay.\u001b[0m\r\n    API key: ✓  Private key: ✓\r\n    Tools: mono_balance, mono_transfer, mono_transactions\r\n\r\n"]
